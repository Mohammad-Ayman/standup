# Postgres connection string (docker-compose services override the host to `postgres`)
DATABASE_URL=postgres://standup:standup@localhost:5432/standup

# Auth.js (next-auth v5) session encryption secret
# openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth app credentials (used for dashboard sign-in)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Canonical URL of the web app
AUTH_URL=http://localhost:3000

# AES-256-GCM key for encrypting secrets at rest (must decode to exactly 32 bytes)
# openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# Comma-separated GitHub usernames allowed to sign in
ALLOWED_GITHUB_LOGINS=

# --- Optional bootstrap fallbacks (normally managed via the settings UI) ---
# GitHub Personal Access Token used before per-user tokens are configured
# GITHUB_PAT=
# Claude Code subscription OAuth token for the planner/executor agents
# CLAUDE_CODE_OAUTH_TOKEN=
# Model used to generate per-issue plans
# PLANNER_MODEL=claude-sonnet-4-6
# Model used to execute approved plans
# EXECUTOR_MODEL=claude-opus-4-8
